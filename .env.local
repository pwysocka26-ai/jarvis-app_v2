ENV=local
API_HOST=127.0.0.1
API_PORT=8010

# Memory backend
MEMORY_BACKEND=db

# Postgres (Docker)
DATABASE_URL=postgresql+psycopg://jarvis:jarvis@127.0.0.1:5432/jarvis
REDIS_URL=redis://127.0.0.1:6379/0

API_TOKEN=dev-token

# Local LLM (optional)
USE_OLLAMA=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_S=180
