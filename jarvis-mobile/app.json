{
  "expo": {
    "name": "Jarvis Mobile",
    "slug": "jarvis-mobile",
    "version": "1.0.0",
    "scheme": "com.anonymous.jarvismobile",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.anonymous.jarvismobile",
      "permissions": [
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-speech-recognition"
    ]
  }
}
